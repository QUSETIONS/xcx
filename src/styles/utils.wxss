/**
 * 全局工具样式 - 交互增强
 * 在 App.vue 中引入
 */

/* 卡片按压反馈 */
.card-press {
  transition: all 0.15s ease;
}
.card-press:active {
  transform: scale(0.97);
  opacity: 0.85;
}

/* 按钮按压反馈 */
.btn-press {
  transition: all 0.1s ease;
}
.btn-press:active {
  transform: scale(0.95);
}

/* 列表项按压反馈 */
.list-press {
  transition: background 0.15s ease;
}
.list-press:active {
  background: #F0F1F5 !important;
}

/* 页面淡入 */
.page-fade {
  animation: pageFade 0.3s ease-out;
}
@keyframes pageFade {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* 内容区域淡入上移 */
.content-rise {
  animation: contentRise 0.4s ease-out;
}
@keyframes contentRise {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 骨架屏通用样式 */
.skeleton-block {
  background: linear-gradient(90deg, #F0F1F5 25%, #E8E9ED 50%, #F0F1F5 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 8rpx;
}
@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 通用空状态 */
.empty-state-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}
.empty-state-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}
.empty-state-text {
  font-size: 28rpx;
  color: rgba(0,0,0,0.4);
  margin-bottom: 24rpx;
}
.empty-state-btn {
  font-size: 26rpx;
  color: #FF6B35;
  background: rgba(255,107,53,0.1);
  padding: 14rpx 40rpx;
  border-radius: 32rpx;
}

/* 通用加载 */
.loading-dot {
  display: inline-block;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #FF6B35;
  margin: 0 4rpx;
  animation: dotPulse 1.4s infinite ease-in-out both;
}
.loading-dot:nth-child(1) { animation-delay: -0.32s; }
.loading-dot:nth-child(2) { animation-delay: -0.16s; }
@keyframes dotPulse {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}

/* 渐变文字 */
.text-gradient {
  background: linear-gradient(135deg, #FF6B35, #FF9A5C);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

/* 通用渐变按钮 */
.btn-gradient {
  background: linear-gradient(135deg, #FF6B35, #FF9A5C);
  color: #FFFFFF;
  border-radius: 32rpx;
  padding: 20rpx 48rpx;
  font-size: 28rpx;
  font-weight: bold;
  text-align: center;
  transition: all 0.15s ease;
}
.btn-gradient:active {
  transform: scale(0.96);
  opacity: 0.9;
}

/* 通用标签 */
.tag-base {
  display: inline-block;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 8rpx;
}
.tag-primary { color: #FF6B35; background: rgba(255,107,53,0.1); }
.tag-blue { color: #6366F1; background: rgba(99,102,241,0.1); }
.tag-green { color: #10B981; background: rgba(16,185,129,0.1); }
.tag-orange { color: #F59E0B; background: rgba(245,158,11,0.1); }
.tag-pink { color: #EC4899; background: rgba(236,72,153,0.1); }